{
	"name": "blobsculptor",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev:svelte": "vite dev",
		"dev:python": "set APP_ENV=development&& nodemon --watch . --ext py --exec python main.py",
		"dev": "concurrently \"npm run dev:svelte\" \"npm run dev:python\"",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"lint": "prettier --check .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"concurrently": "^9.2.1",
		"nodemon": "^3.1.14",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.54.0",
		"tailwindcss": "^4.1.18",
		"vite": "^7.3.1"
	}
}
